# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BRAND_NAME="Positive On Worldwide"
NODE_ENV=development

# Database (Neon Postgres)
DATABASE_URL=postgres://...

# Auth0
AUTH0_SECRET=generate-a-32-character-secret
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://YOUR_DOMAIN.auth0.com
AUTH0_CLIENT_ID=YOUR_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_CLIENT_SECRET

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SUCCESS_URL=http://localhost:3000/orders?checkout=success
STRIPE_CANCEL_URL=http://localhost:3000/checkout?checkout=cancelled

# Admin
ADMIN_EMAILS=owner@example.com,admin@example.com
