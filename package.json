    "lucide-react": "^0.395.0",
    "next": "14.2.25",
    "pg": "^8.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^15.11.0",
    "tailwind-merge": "^2.3.0",
    "three": "^0.165.0",
